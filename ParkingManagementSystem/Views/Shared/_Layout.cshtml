<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Parking Management System</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <div class="container header-inner">
            <a class="brand" asp-controller="Home" asp-action="Index">
                <span class="brand-mark">P</span>
                <span class="brand-name">Parking Management</span>
            </a>
            <nav class="main-nav">
                @if (CurrentUser.IsAuthenticated)
                {
                    <a asp-controller="Home" asp-action="Dashboard">Dashboard</a>
                    <a asp-controller="Slots" asp-action="Index">Slots</a>
                    <a asp-controller="Reservations" asp-action="Index">My Reservations</a>
                    <a asp-controller="Profile" asp-action="Index">My Profile</a>
                    if (CurrentUser.IsAdmin)
                    {
                        <a asp-controller="AdminSlots" asp-action="Index">Manage Slots</a>
                        <a asp-controller="AdminReservations" asp-action="Index">Reservations</a>
                        <a asp-controller="Scanner" asp-action="Index">Scanner</a>
                        <a asp-controller="Admin" asp-action="Users">Users</a>
                    }
                    <span class="nav-user">Hi, @CurrentUser.FullName</span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-link">Sign out</button>
                    </form>
                }
                else
                {
                    <a asp-controller="Slots" asp-action="Index">Slots</a>
                    <a asp-controller="Account" asp-action="Login">Sign in</a>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-sm">Create account</a>
                }
            </nav>
        </div>
    </header>

    <main class="container site-main">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-error">@TempData["ErrorMessage"]</div>
        }
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">
            <span>&copy; @DateTime.Now.Year Parking Management System</span>
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
