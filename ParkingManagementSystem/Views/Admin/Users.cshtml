@model IReadOnlyList<User>
@{
    ViewData["Title"] = "User Management";
}

<div class="page-header">
    <div>
        <h1>User Management</h1>
        <p class="muted">Create, edit, and remove user accounts. (@Model.Count total)</p>
    </div>
    <a asp-action="CreateUser" class="btn btn-primary">+ New user</a>
</div>

<div class="card">
    @if (Model.Count == 0)
    {
        <p class="muted">No users registered yet.</p>
    }
    else
    {
        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Plate</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Registered</th>
                        <th class="actions-col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var isSelf = CurrentUser.UserId == user.Id;
                        <tr>
                            <td>@user.Id</td>
                            <td>
                                @user.FullName
                                @if (isSelf) { <span class="muted">(you)</span> }
                            </td>
                            <td>@user.Email</td>
                            <td>@user.PhoneNumber</td>
                            <td><span class="plate-badge plate-badge-sm">@user.VehiclePlateNumber</span></td>
                            <td><span class="role-badge role-@user.Role.ToLower()">@user.Role</span></td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="status-badge status-active">Active</span>
                                }
                                else
                                {
                                    <span class="status-badge status-inactive">Inactive</span>
                                }
                            </td>
                            <td class="muted">@user.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="actions-col">
                                <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-secondary btn-sm">Edit</a>
                                @if (!isSelf)
                                {
                                    <a asp-action="DeleteUser" asp-route-id="@user.Id" class="btn btn-danger btn-sm">Delete</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
