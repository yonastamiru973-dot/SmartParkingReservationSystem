@model AdminUserFormViewModel
@{
    ViewData["Title"] = $"Edit User — {Model.FullName}";
    var isSelf = CurrentUser.UserId == Model.Id;
}

<div class="page-header">
    <h1>Edit User</h1>
    <a asp-action="Users" class="btn btn-secondary">Back to list</a>
</div>

<div class="card narrow">
    @if (isSelf)
    {
        <p class="muted admin-self-note">You are editing your own account. You cannot remove your admin role or deactivate yourself.</p>
    }

    <form asp-action="EditUser" asp-route-id="@Model.Id" method="post" novalidate>
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
        <input type="hidden" asp-for="Id" />

        <div class="form-row">
            <label asp-for="FullName"></label>
            <input asp-for="FullName" class="form-input" />
            <span asp-validation-for="FullName" class="field-error"></span>
        </div>

        <div class="form-row">
            <label asp-for="Email"></label>
            <input asp-for="Email" class="form-input" type="email" />
            <span asp-validation-for="Email" class="field-error"></span>
        </div>

        <div class="form-grid-2">
            <div class="form-row">
                <label asp-for="PhoneNumber"></label>
                <input asp-for="PhoneNumber" class="form-input" />
                <span asp-validation-for="PhoneNumber" class="field-error"></span>
            </div>
            <div class="form-row">
                <label asp-for="VehiclePlateNumber"></label>
                <input asp-for="VehiclePlateNumber" class="form-input" />
                <span asp-validation-for="VehiclePlateNumber" class="field-error"></span>
            </div>
        </div>

        <div class="form-grid-2">
            <div class="form-row">
                <label asp-for="Role"></label>
                <select asp-for="Role" class="form-input" disabled="@(isSelf)">
                    <option value="User">User</option>
                    <option value="Admin">Admin</option>
                </select>
                @if (isSelf)
                {
                    <input type="hidden" asp-for="Role" />
                }
                <span asp-validation-for="Role" class="field-error"></span>
            </div>
            <div class="form-row inline-row" style="align-self: end;">
                <label class="checkbox">
                    <input asp-for="IsActive" disabled="@(isSelf)" />
                    <span>Active account</span>
                </label>
                @if (isSelf)
                {
                    <input type="hidden" asp-for="IsActive" />
                }
            </div>
        </div>

        <p class="muted password-hint">Leave password blank to keep the current password.</p>
        <div class="form-grid-2">
            <div class="form-row">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-input" autocomplete="new-password" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>
            <div class="form-row">
                <label asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword" class="form-input" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>
        </div>

        <div class="form-actions">
            <a asp-action="Users" class="btn btn-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary">Save changes</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
