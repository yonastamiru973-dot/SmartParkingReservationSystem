@{
    ViewData["Title"] = "Check your email";
}

<div class="auth-shell">
    <div class="auth-card">
        <h1>Check your email</h1>
        <p>
            If an account exists for the email you provided, we've sent reset instructions
            to it. The link will expire in 1 hour.
        </p>
        <p class="muted">
            (Development mode: the reset link is also logged to <code>App_Data/password-reset-emails.log</code>.)
        </p>
        <a asp-action="Login" class="btn btn-secondary">Back to sign in</a>
    </div>
</div>
