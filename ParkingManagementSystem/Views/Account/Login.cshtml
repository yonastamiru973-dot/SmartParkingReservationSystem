@model LoginViewModel
@{
    ViewData["Title"] = "Sign in";
}

<div class="auth-shell">
    <div class="auth-card">
        <h1>Sign in</h1>
        <p class="muted">Welcome back. Enter your credentials to continue.</p>

        <form asp-action="Login" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
            <input type="hidden" asp-for="ReturnUrl" />

            <div class="form-row">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-input" type="email" autocomplete="email" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-input" autocomplete="current-password" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="form-row inline-row">
                <label class="checkbox">
                    <input asp-for="RememberMe" /> <span>Remember me</span>
                </label>
                <a asp-action="ForgotPassword">Forgot password?</a>
            </div>

            <button type="submit" class="btn btn-primary btn-block">Sign in</button>
        </form>

        <p class="auth-foot">
            Don't have an account?
            <a asp-action="Register">Create one</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
