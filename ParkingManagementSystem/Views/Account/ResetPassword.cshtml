@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset password";
}

<div class="auth-shell">
    <div class="auth-card">
        <h1>Reset your password</h1>
        <p class="muted">Choose a new password for <strong>@Model.Email</strong>.</p>

        <form asp-action="ResetPassword" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
            <input type="hidden" asp-for="Token" />
            <input type="hidden" asp-for="Email" />

            <div class="form-row">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-input" autocomplete="new-password" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword" class="form-input" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-block">Reset password</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
