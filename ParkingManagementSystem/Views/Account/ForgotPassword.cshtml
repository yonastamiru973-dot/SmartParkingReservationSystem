@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot password";
}

<div class="auth-shell">
    <div class="auth-card">
        <h1>Forgot your password?</h1>
        <p class="muted">Enter the email associated with your account. We'll send you a reset link.</p>

        <form asp-action="ForgotPassword" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-row">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-input" type="email" autocomplete="email" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-block">Send reset link</button>
        </form>

        <p class="auth-foot">
            <a asp-action="Login">Back to sign in</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
