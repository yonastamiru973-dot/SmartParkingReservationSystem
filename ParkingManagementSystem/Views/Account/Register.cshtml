@model RegisterViewModel
@{
    ViewData["Title"] = "Create your account";
}

<div class="auth-shell">
    <div class="auth-card">
        <h1>Create your account</h1>
        <p class="muted">Sign up to start reserving parking spots.</p>

        <form asp-action="Register" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-row">
                <label asp-for="FullName"></label>
                <input asp-for="FullName" class="form-input" autocomplete="name" />
                <span asp-validation-for="FullName" class="field-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-input" type="email" autocomplete="email" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="form-grid-2">
                <div class="form-row">
                    <label asp-for="PhoneNumber"></label>
                    <input asp-for="PhoneNumber" class="form-input" autocomplete="tel" />
                    <span asp-validation-for="PhoneNumber" class="field-error"></span>
                </div>
                <div class="form-row">
                    <label asp-for="VehiclePlateNumber"></label>
                    <input asp-for="VehiclePlateNumber" class="form-input" />
                    <span asp-validation-for="VehiclePlateNumber" class="field-error"></span>
                </div>
            </div>

            <div class="form-grid-2">
                <div class="form-row">
                    <label asp-for="Password"></label>
                    <input asp-for="Password" class="form-input" autocomplete="new-password" />
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>
                <div class="form-row">
                    <label asp-for="ConfirmPassword"></label>
                    <input asp-for="ConfirmPassword" class="form-input" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="field-error"></span>
                </div>
            </div>

            <button type="submit" class="btn btn-primary btn-block">Create account</button>
        </form>

        <p class="auth-foot">
            Already have an account?
            <a asp-action="Login">Sign in</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
