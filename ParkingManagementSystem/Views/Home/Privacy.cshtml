@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="card narrow">
    <h1>Privacy Policy</h1>
    <p>
        We collect only the information needed to run the Parking Management System:
        your name, contact details, and vehicle plate number. Passwords are stored as
        secure one-way hashes (BCrypt) and are never stored or transmitted in plain text.
    </p>
    <p>
        Your data is used solely to operate the parking reservation features and to
        contact you about your account. We do not sell or share your information with
        third parties.
    </p>
</div>
