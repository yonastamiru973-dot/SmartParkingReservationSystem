@model ParkingSlot
@{
    ViewData["Title"] = $"Delete Slot {Model.SlotNumber}";
}

<div class="page-header">
    <h1>Delete Slot</h1>
    <a asp-action="Index" class="btn btn-secondary">Back to list</a>
</div>

<div class="card narrow">
    <p>Are you sure you want to delete slot <strong>@Model.SlotNumber</strong>?</p>
    <p class="muted">
        This is a soft delete &mdash; the slot is hidden from users but its history is preserved in the database.
    </p>

    <dl class="info-list">
        <div class="info-row"><dt>Type</dt><dd>@Model.SlotType</dd></div>
        <div class="info-row"><dt>Status</dt><dd>@Model.Status</dd></div>
        <div class="info-row"><dt>Hourly Rate</dt><dd>@Model.HourlyRate.ToString("C")</dd></div>
        <div class="info-row">
            <dt>Location</dt>
            <dd class="muted">@Model.Latitude.ToString("F5"), @Model.Longitude.ToString("F5")</dd>
        </div>
    </dl>

    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <div class="form-actions">
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            <button type="submit" class="btn btn-danger">Yes, delete slot</button>
        </div>
    </form>
</div>
